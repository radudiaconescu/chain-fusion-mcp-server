# Required: Path to your ICP identity PEM file
# Generate with: dfx identity export <name> > identity.pem
ICP_IDENTITY_PEM=./identity.pem

# ICP network: mainnet (default) or testnet (local dfx)
ICP_NETWORK=mainnet

# MCP transport: stdio (default), sse, or both
MCP_TRANSPORT=stdio

# Port for SSE transport (default: 3000)
MCP_SSE_PORT=3000

# Override ICP node URL (default: https://ic0.app)
# ICP_NODE_URL=https://ic0.app

# Override Bitcoin API base URL (default: mempool.space)
# BTC_API_URL=https://mempool.space/api

# Ethereum JSON-RPC endpoint (required for ETH tools)
# ETH_RPC_URL=https://mainnet.infura.io/v3/YOUR_KEY

# Read cache TTL in milliseconds (default: 10000 = 10s)
# CACHE_TTL_MS=10000
